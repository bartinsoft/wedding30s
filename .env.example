NODE_ENV=development
PORT=3000
BASE_URL=https://wedding30s.com

# Database (MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=wedding30s
DB_PASSWORD=wedding30s_dev
DB_NAME=wedding30s

# Auth
JWT_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Polar LIVE (todos los usuarios)
POLAR_ACCESS_TOKEN=polar_at_...
POLAR_WEBHOOK_SECRET=...
POLAR_PRODUCT_ID=...

# Polar SANDBOX (emails @bartinsoft.com y desarrollo)
POLAR_ACCESS_TOKEN_TEST=polar_at_...
POLAR_WEBHOOK_SECRET_TEST=...
POLAR_PRODUCT_ID_TEST=...

# SMTP (Amazon SES)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=support@wedding30s.com
SUGGESTIONS_BCC=

# Google Chat webhook
GOOGLE_CHAT_WEBHOOK=

# Cloudflare Turnstile
TURNSTILE_SECRET=
VITE_TURNSTILE_SITE_KEY=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
S3_BUCKET=wedding30s
