{
  "name": "wedding30s",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json && tsx scripts/prerender.ts",
    "start": "node dist/server/index.js",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "seed:blog": "tsx src/server/scripts/seed-blog.ts",
    "cleanup:drafts": "tsx src/server/scripts/cleanup-drafts.ts",
    "seed:demo": "tsx src/server/scripts/seed-demo.ts",
    "backup:db": "tsx src/server/scripts/backup-db.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "@polar-sh/sdk": "^0.46.7",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.20.0",
    "nanoid": "^5.0.0",
    "nodemailer": "^8.0.4",
    "sharp": "^0.33.0",
    "vue-i18n": "^11.3.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.0",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  }
}
